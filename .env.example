# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative name supported by lib/env.ts:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (required in production for auth redirects, emails, metadata)
# Local development only. On Vercel, VERCEL_PROJECT_PRODUCTION_URL is used automatically.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Optional: comma-separated LAN IPs/hostnames so teammates can load the dev app (e.g. 192.168.1.42)
# DEV_ALLOWED_ORIGINS=192.168.1.42

# Email (required for production notifications)
# Brevo SMTP is preferred when BREVO_SMTP_KEY + BREVO_SMTP_LOGIN are set.
# Brevo REST API is used when BREVO_API_KEY is set (xkeysib-... key from Brevo dashboard).
# Resend is the fallback when Brevo is not configured.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_API_KEY=
BREVO_FROM_EMAIL=orders@mithron.co
BREVO_FROM_NAME=Mithron India Smart Services Pvt Ltd
RESEND_API_KEY=
EMAIL_FROM=Mithron <noreply@mithron.com>

# Distributed rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth audit client HMAC (required for anonymous failed-login telemetry in production)
AUTH_AUDIT_CLIENT_SECRET=

# Optional client observability endpoint
NEXT_PUBLIC_OBSERVABILITY_ENDPOINT=

# Session idle timeout used by proxy (minutes)
SESSION_TIMEOUT_MINUTES=60

# Auth providers (Google OAuth + email/password via Supabase)
AUTH_PROVIDER_GOOGLE_ENABLED=true
AUTH_PROVIDER_EMAIL_ENABLED=true
# Require enrolled MFA metadata for admin accounts after sign-in
AUTH_ADMIN_MFA_REQUIRED=false
# Supabase dashboard: enable Google provider under Authentication → Providers.
# Add these redirect URLs under Authentication → URL configuration:
#   http://127.0.0.1:3000/auth/callback
#   https://<your-production-domain>/auth/callback

# Payments (required before accepting real checkout)
PAYMENT_PROVIDER=razorpay

# Internal service tokens (use 32+ cryptographically random bytes each)
NOTIFICATION_DISPATCH_SECRET=
PAYMENT_EXPIRE_SECRET=
CRON_SECRET=
MITHRON_ASSET_UPLOAD_TOKEN=
# Set to true after canonical media backfill; retires POST /api/upload (admin media library is the supported path)
MITHRON_UPLOAD_API_RETIRED=true
HEALTH_CHECK_SECRET=

# Media upload size cap (bytes, default 52428800 = 50 MB)
MEDIA_MAX_UPLOAD_BYTES=52428800

# Internal operator seed tooling only (npm run seed:reset-demo-users)
# ALLOW_DEMO_SEED=true
# DEMO_ADMIN_PASSWORD=
# DEMO_SUPPLIER_PASSWORD=
# DEMO_WAREHOUSE_PASSWORD=

# Production E2E credentials (npm run e2e:prod — never commit real passwords)
# PLAYWRIGHT_BASE_URL=https://mithron-flight-systems-kbkbkh.vercel.app
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_WAREHOUSE_EMAIL=
# E2E_WAREHOUSE_PASSWORD=
# E2E_SUPPLIER_EMAIL=
# E2E_SUPPLIER_PASSWORD=
# E2E_ALLOW_MUTATIONS=false
# LIVE_ADMIN_PASSWORD=
# LIVE_SUPPLIER_PASSWORD=
# LIVE_WAREHOUSE_PASSWORD=
# NEXT_PUBLIC_STOREFRONT_GUEST_ONLY=true

# Payment provider credentials (when PAYMENT_PROVIDER=stripe or razorpay)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Cashfree (when PAYMENT_PROVIDER=cashfree or dual-provider checkout)
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=
# CASHFREE_WEBHOOK_SECRET=
# CASHFREE_ENV=production

# Optional SMS (Twilio service exists but is not wired to workflows yet)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Default warehouse for checkout reservation and inventory seeding
DEFAULT_WAREHOUSE_CODE=IN-WEST-01
DEFAULT_SUPPLIER_INTAKE_WAREHOUSE_CODE=IN-WEST-01

# Wix Stores API (catalog reconciliation tooling only)
WIX_STUDIO_API_KEY=
WIX_SITE_ID=aca2c10f-62df-404a-be24-d15cc3f32d34

# CMS (production: strict mode is enabled automatically when NODE_ENV=production)
# MITHRON_CMS_STRICT=true
# MITHRON_CMS_REVISION_DEBUG=true
